# ── External contract addresses ──────────────────────────────────────────────

# USDC ERC-20 contract on the target chain
# Polygon mainnet: 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# ProphetCTFExchange contract on the target chain
EXCHANGE_ADDRESS=0x0000000000000000000000000000000000000000

# Gnosis ConditionalTokens (ERC-1155) contract on the target chain
# Polygon mainnet: 0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
CTF_ADDRESS=0x0000000000000000000000000000000000000000

# ── Role wallet addresses (NOT private keys) ─────────────────────────────────

# Initial Admin — registry-only authority (add/remove operators, set oracle,
# pause trading, schedule/apply/cancel implementation upgrades)
ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# Initial Oracle — vault lifecycle authority (createVault, startWindDown)
# MUST be a DIFFERENT wallet from OPERATOR_ADDRESS (constructor enforces this)
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# Initial Operator — transactional authority (mintPositionFor, notifyFees,
# updateTick, mergePositions)
# MUST be a DIFFERENT wallet from ORACLE_ADDRESS
OPERATOR_ADDRESS=0x0000000000000000000000000000000000000000

# ── Verification ─────────────────────────────────────────────────────────────

# Etherscan API key — REQUIRED for --verify. Without it the deployment
# broadcast still succeeds but the contract is left UNVERIFIED on Polygonscan.
# One key works across all Etherscan V2 supported chains (including Polygon).
# Get one free at https://etherscan.io/apis
ETHERSCAN_API_KEY=
